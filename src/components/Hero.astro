---
const { title = "FÍSICA REAL,", subtitle = "EXPLICADA SIMPLE." } = Astro.props;
---

<section class="hero">
    <div class="glow-capture"></div>

    <div class="hero-content">
        <h1>
            {title}<br/>
            <span class="text-gradient">{subtitle}</span>
        </h1>
        
        <p class="hero-description">
            ¿Profesor que no explica? ¿Ingreso a la facultad sin base? Te damos la profundidad técnica que la escuela omitió con resúmenes de alta densidad, sin relleno.
        </p>

        <div class="cta-group">
            <a href="/aximple/temas" class="btn btn-primary">
                Explorar Temas
            </a>
            <a href="/aximple/laboratorio" class="btn btn-secondary">
                Laboratorio de Pruebas
            </a>
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        min-height: 84vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background: radial-gradient(
            circle at 50% 50%, 
            var(--accent-glow) -80%, 
            transparent 40%
        );
    }

    .hero::before {
        content: "";
        position: absolute;
        top: -100px;
        left: -60px;
        rotate: -15deg;
        width: 100%;
        height: 100%;
        background-image: url('/hero-diagram.png'); 
        background-position: center;
        background-repeat: no-repeat;
        background-size: 1000px;
        opacity: 0.1; 
        filter: blur(14px) hue-rotate(10deg);
        pointer-events: none;
        z-index: 0;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        max-width: 1000px;
        text-align: center;
        padding: 0 1.5rem;
    }

    h1 {
        font-size: clamp(2.5rem, 8vw, 5.5rem);
        font-weight: 850;
        line-height: 1;
        letter-spacing: -0.04em;
        color: var(--text-main);
        margin-bottom: 1.5rem;
    }

    .text-gradient {
        background: var(--gradient-brand);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: inline-block;
    }

    .hero-description {
        font-size: 1.25rem;
        color: var(--text-muted);
        max-width: 650px;
        margin: 0 auto 3rem;
        line-height: 1.6;
    }

    .cta-group {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        align-items: center;
    }

    .btn {
        padding: 1.2rem 2.5rem;
        border-radius: 16px;
        font-size: 1.1rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
    }

    .btn-primary {
        background-color: var(--accent-secondary);
        color: var(--text-dark);
    }

    .btn-primary:hover {
        background-color: #d9ff96;
        box-shadow: 0 10px 30px var(--secondary-glow);
        transform: translateY(-2px);
    }

    .btn-secondary {
        background-color: var(--btn-secondary);
        color: var(--text-main);
        border: 1px solid var(--border-soft);
        backdrop-filter: blur(10px);
    }

    .btn-secondary:hover {
        background-color: rgba(var(--white-rgb), 0.1);
        border-color: var(--border-accent);
    }

    @media (max-width: 768px) {
        h1 { 
            font-size: 4rem; 
            letter-spacing: -2px; 
        }

        .cta-group { 
            flex-direction: column; 
            width: 100%; 
        }

        .btn { 
            width: 100%; 
            justify-content: center; 
        }

        .hero-description { 
            font-size: 1.2rem; 
        }
    }
</style>