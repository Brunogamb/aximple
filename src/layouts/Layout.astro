---
const { title } = Astro.props;

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="es">
	<head>
        <title>{title}</title>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/aximple/favicon.png" />
		<meta name="generator" content={Astro.generator} />
        
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
        <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
        <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
        <script is:inline>
            function renderPhysics() {
                renderMathInElement(document.body, {
                delimiters: [
                    {left: '$', right: '$', display: false}
                ],
                throwOnError : false
                });
            }
            document.addEventListener('DOMContentLoaded', renderPhysics);
            document.addEventListener('astro:page-load', renderPhysics);
        </script>
	</head>
	<body>
		<Header />
		<slot />
        <Footer />
	</body>
</html>

<style is:global>
:root {
    --bg: #121826;             
    --bg-dark: #0a0f18;     
    --card-bg: #1c2536;    
    --card-bg-glass: rgba(28, 37, 54, 0.6); 
    --card-hover: #242f44;   

    --accent: #22d3ee;    
    --accent-secondary: #bef264;
    --accent-glow: rgba(34, 211, 238, 0.3);
    --secondary-glow: rgba(190, 242, 100, 0.3);
    
    --text-main: #f8fafc;     
    --text-muted: #94a3b8;     
    --text-dark: #020617;      
    --white-rgb: 248, 250, 252; 

    --border-soft: rgba(255, 255, 255, 0.08); 
    --border-accent: rgba(34, 211, 238, 0.2);
    
    --btn-primary: var(--accent-secondary);
    --btn-secondary: rgba(30, 41, 59, 0.5);
    
    --gradient-brand: linear-gradient(to right, var(--accent), var(--accent-secondary));
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    overflow-y: scroll;
    scroll-behavior: smooth;
}

html, 
body {
    background-color: var(--bg);
}

body {
    font-family: 'Outfit', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    color: var(--text-main);
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    overflow-x: hidden;
    padding-top: 80px;
}

header, 
main, 
footer {
    width: 100%;
}

main {
    flex: 1;
}

a {
    text-decoration: none;
    color: inherit;
}

::-webkit-scrollbar {
    width: 16px;
}

::-webkit-scrollbar-track {
    background-color: var(--bg);
    background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 4px 4px;
    border-left: 1px solid var(--border-soft);
}

::-webkit-scrollbar-thumb {
    background-image: radial-gradient(
        circle,
        var(--accent-secondary) 0.5px, 
        transparent 1.5px
    );
    background-size: 4px 4px;
    border: 4px solid var(--bg);
    box-shadow: 0 0 20px var(--secondary-glow);
    border-radius: 0;
}

::-webkit-scrollbar-thumb:hover {
    background-image: radial-gradient(
        circle,
        var(--accent) 0.5px, 
        transparent 1.5px
    );
    cursor: pointer;
    border-radius: 6px;
}

::-webkit-scrollbar-corner {
    background: var(--bg);
}
</style>
